<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloggy - Feed</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

        <div class="w-full flex justify-end gap-2">
            <a class="bg-red-500 rounded-md text-sm px-3 py-2 inline-block mb-5" href="/feed">Feed</a>
            <a class="bg-red-500 rounded-md text-sm px-3 py-2 inline-block mb-5" href="/profile">My Profile</a>
            <a class="bg-red-500 rounded-md text-sm px-3 py-2 inline-block mb-5" href="/logout">Logout</a>
        </div>

        <h3 class="text-xl text-zinc-400 mt-5 mb-5">NewsFeed.</h3>

        <div class="postcontainer mt-5">

            <% if(posts.length === 0) { %>
                <p class="text-zinc-500 text-sm">No posts yet. Be the first to post something!</p>
            <% } %>

            <% posts.forEach(function(post) { %>
                <div class="post w-1/3 p-4 border-2 bg-zinc-800 border-zinc-700 rounded-md mb-4">

                    <div class="flex items-center gap-3 mb-3">
                        <img 
                            class="w-8 h-8 rounded-full object-cover"
                            src="/images/uploads/<%= post.user.profilepic %>" 
                            alt="pfp" 
                        />
                        <h4 class="text-blue-300">@<%= post.user.username %></h4>
                    </div>

                    <p class="text-xl font-bold text-zinc-500 tracking-tight mb-1.5"><%= post.title %></p>
                    <p class="text-sm tracking-tight"><%= post.content %></p>

                    <small class="text-zinc-600 mt-2 inline-block"><%= post.date.toDateString() %></small>

                    <div class="mt-2">
                        <small class="text-blue-200"><%= post.likes.length %> likes</small>
                        <div class="btns flex mt-1 gap-4">
                            <% let alreadyLiked = post.likes.some(id => id.toString() === user._id.toString()); %>
                            <form action="/like/<%= post._id %>" method="POST">
                                <button type="submit" class="text-blue-300 cursor-pointer">
                                    <%= alreadyLiked ? "Unlike" : "Like" %>
                                </button>
                            </form>
                        </div>
                    </div>



        <!-- Comments Section -->
        <div class="mt-4 border-t border-zinc-700 pt-3">

            <!-- Comment Form -->
            <form action="/comment/<%= post._id %>" method="POST" class="flex gap-2 mb-3">
                <input 
                    type="text" 
                    name="content"
                    placeholder="Write a comment..."
                    class="flex-1 bg-transparent border border-zinc-700 rounded-md px-3 py-1 text-sm outline-none text-white"
                />
                <button type="submit" class="text-blue-300 text-sm cursor-pointer">Post</button>
            </form>

            <!-- Comments List -->
            <% if(post.comments.length > 0) { %>
                <% post.comments.forEach(function(comment) { %>
                    <% if(comment.user) { %>  
                        <div class="flex items-start gap-2 mb-2">
                            <span class="text-blue-300 text-xs mt-0.5">@<%= comment.user.username %></span>
                            <span class="text-zinc-300 text-xs"><%= comment.content %></span>
                        </div>
                     <% } %>
                <% }) %>
            <% } else { %>
                <p class="text-zinc-600 text-xs">No comments yet.</p>
            <% } %>

        </div>

                </div>
            <% }) %>

        </div>
    </div>
</body>
</html>