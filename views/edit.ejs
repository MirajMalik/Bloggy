<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloggy</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md text-sm px-3 py-2 inline-block mb-5" href="/logout">Logout</a>
        </div>

        <h5 class="mb-5">Edit your post.</h5>
        <form action="/update/<%= post._id %>" method="post">
            <textarea class="w-1/3 p-3 resize-none block bg-transparent border-2 border-zinc-800 outline-none roubded-md" placeholder="What's on your mind?" name="content"><%= post.content %></textarea>
            <input class="px-3 w-40 py-2 bg-yellow-500 text-black block rounded-md mt-3 text-sm" type="submit" value="Update Post">
        </form>
    </div>
    
</body>
</html>