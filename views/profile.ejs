<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloggy</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="w-full flex justify-end">
            <a class="bg-red-500 rounded-md text-sm px-3 py-2 inline-block mb-5" href="/logout">Logout</a>
        </div>
 
        <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-md">
                 <% if (user) { %>
                        <img class="h-full w-full object-cover overflow-hidden" src="/images/uploads/<%= user.profilepic %>" alt="Profile Picture">
                    <% } else { %>
                        <img class="h-full w-full object-cover overflow-hidden" src="/images/uploads/default.png" alt="Default">
                    <% } %>
            </div>
            <h3 class="text-2xl"><span class="font-light">Hello</span>, <%= user.name %></h3>
        </div>

        
        <h5 class="mb-5 mt-5">Create a new post.</h5>
        <form action="/post" method="post">
            <textarea class="w-1/3 p-3 mb-2 overflow-hidden leading-tight resize-none block bg-transparent border-2 border-zinc-800 outline-none rounded-md" name="title" placeholder="Title of the post"></textarea>
            <textarea class="w-1/3 p-3 leading-tight resize-none block bg-transparent border-2 border-zinc-800 outline-none rounded-md" name="content" placeholder="What's on your mind?" ></textarea>
            <input class="px-3 w-40 py-2 bg-blue-500 block rounded-md mt-3 text-sm" type="submit" value="Create new post">
        </form>

        <div class="posts mt-20">
            <h3 class="text-xl text-zinc-400">Your Posts.</h3>
            <div class="postcontainer mt-5">
                <% user.posts.reverse().forEach(function(post){  %>
                    <div class="post w-1/3 p-4 border-2 bg-zinc-800 border-zinc-700 rounded-md mb-4">
                        <h4 class="text-blue-300 mb-2">@<%= user.username %></h4>
                        <p class="text-xl font-bold text-zinc-500 tracking-tight mb-1.5"><%= post.title %></p>
                        <p class="text-sm tracking-tight"><%= post.content %></p>
                        <small class="mt-2 inline-block text-blue-200"><%= post.likes.length %> likes</small>
                        <div class="btns flex mt-1 gap-4">
                            <a class="text-blue-300" href="/like/<%= post._id %>">
                               <%= post.likes.indexOf(user._id) === -1 ?  "Like" :  "Unlike" %>
                            </a>
                            <a class="text-zinc-600" href="/edit/<%= post._id %>">Edit</a>
                        </div>
                     </div>
                <% }) %>
            </div>
        </div>



    </div>
    
</body>
</html>