<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloggy Register</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 text-white font-sans">

    <div class="w-full min-h-screen flex flex-col items-center justify-center p-6">
        
        <div class="p-6 md:absolute md:top-8 md:left-10 text-center md:text-left">
            <h1 class="text-3xl font-black tracking-tighter">
                <span class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent">
                    Bloggy
                </span>
            </h1>
        </div>
        
        <div class="w-full max-w-md bg-zinc-900/50 p-8 rounded-xl border border-zinc-800 shadow-2xl">
            <h1 class="mb-8 text-blue-500 text-4xl font-bold tracking-tight">Create Account</h1>
            
            <form action="/register" method="post" autocomplete="off" class="flex flex-col gap-4">
                
                <input class="w-full h-12 px-4 rounded-md outline-none bg-transparent border-2 border-zinc-800 focus:border-blue-900 transition-all placeholder:text-zinc-500" 
                       type="text" placeholder="Username" name="username">
                
                <input class="w-full h-12 px-4 rounded-md outline-none bg-transparent border-2 border-zinc-800 focus:border-blue-900 transition-all placeholder:text-zinc-500" 
                       type="text" placeholder="Full Name" name="name">
                
                <input class="w-full h-12 px-4 rounded-md outline-none bg-transparent border-2 border-zinc-800 focus:border-blue-900 transition-all placeholder:text-zinc-500" 
                       type="email" placeholder="Email Address" name="email">
                
                <div class="flex gap-4">
                    <input class="w-1/3 h-12 px-4 rounded-md outline-none bg-transparent border-2 border-zinc-800 focus:border-blue-900 transition-all placeholder:text-zinc-500" 
                           type="number" placeholder="Age" name="age">
                    
                    <input class="w-2/3 h-12 px-4 rounded-md outline-none bg-transparent border-2 border-zinc-800 focus:border-blue-900 transition-all placeholder:text-zinc-500" 
                           type="password" placeholder="Password" name="password">
                </div>

                <input class="w-full h-12 mt-4 bg-blue-700 hover:bg-blue-600 transition-all rounded-md font-semibold cursor-pointer shadow-lg shadow-blue-900/20" 
                       type="submit" value="Create Account">
            </form>

            <p class="mt-6 text-center text-sm text-zinc-500">
                Already have an account? <a href="/login" class="text-blue-400 hover:underline">Login</a>
            </p>
        </div>

    </div>
    
</body>
</html>