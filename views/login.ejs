<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloggy Login</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-zinc-900 text-white font-sans">

    <div class="w-full min-h-screen flex flex-col items-center justify-center p-6">
        
        <div class="w-full max-w-md bg-zinc-900/50 p-8 rounded-xl border border-zinc-800 shadow-2xl">
            <h1 class="mb-8 text-blue-200 text-4xl font-bold tracking-tight text-center">Login</h1>
            
            <form action="/login" method="post" autocomplete="off" class="flex flex-col gap-5">
                
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-zinc-500 ml-1 uppercase tracking-widest font-semibold">Email Address</label>
                    <input class="w-full h-12 px-4 rounded-md outline-none bg-transparent border-2 border-zinc-800 focus:border-blue-500 transition-all placeholder:text-zinc-600" 
                           type="email" placeholder="Enter your email" name="email">
                </div>
                
                <div class="flex flex-col gap-1">
                    <label class="text-xs text-zinc-500 ml-1 uppercase tracking-widest font-semibold">Password</label>
                    <input class="w-full h-12 px-4 rounded-md outline-none bg-transparent border-2 border-zinc-800 focus:border-blue-500 transition-all placeholder:text-zinc-600" 
                           type="password" placeholder="••••••••" name="password">
                </div>

                <div class="pt-2">
                    <input class="w-full h-12 bg-blue-700 hover:bg-blue-600 active:scale-[0.98] transition-all rounded-md font-semibold cursor-pointer shadow-lg shadow-blue-900/30 text-white" 
                           type="submit" value="Login to Account">
                </div>
            </form>

            <div class="mt-8 pt-6 border-t border-zinc-800 text-center">
                <p class="text-sm text-zinc-500">
                    Don't have an account? 
                    <a href="/" class="text-blue-400 hover:text-blue-300 font-medium transition-colors">Create one here</a>
                </p>
            </div>
        </div>

    </div>
    
</body>
</html>