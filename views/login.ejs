<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloggy</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h1 class="mb-5 text-blue-200 text-3xl">Login Your Account</h1>
        <form action="/login" method="post" autocomplete="off">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" type="email" placeholder="email" name="email">
            <input class="px-3 py-2 rounded-md outline-none bg-transparent border-2 border-zinc-800" type="number" placeholder="password" name="password">
            <input class="px-5 py-2 bg-blue-700 rounded-md" type="submit" value="Login">
        </form>
    </div>
    
</body>
</html>