<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bloggy</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h1 class="mb-5 text-blue-200 text-3xl">Upload Profile Picture</h1>
        <form action="/upload" method="post" autocomplete="off" enctype="multipart/form-data">
           <input class="bg-red-500" type="file" name="image">      
            <input class="px-5 py-2 bg-blue-700 rounded-md" type="submit" value="Upload File">
        </form>
    </div>
    
</body>
</html>